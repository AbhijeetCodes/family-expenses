# Auth.js
NEXTAUTH_SECRET=                         # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000       # change to Vercel URL in production

# Google OAuth (for sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Access control — comma-separated Google email addresses
ALLOWED_EMAILS=you@gmail.com,spouse@gmail.com

# Google Sheets
SHEET_ID=                                # the long ID from the sheet URL
GOOGLE_SERVICE_ACCOUNT_EMAIL=            # xxx@xxx.iam.gserviceaccount.com
# Paste the full private_key value from the service account JSON (include \n line breaks)
GOOGLE_SERVICE_ACCOUNT_KEY=
